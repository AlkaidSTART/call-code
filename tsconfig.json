{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,

    "paths": {
      "@agent-core/*": ["./packages/agent-core/src/*"]
    }
  },
  "include": ["packages/agent-core/src/**/*.ts"],
  "exclude": ["node_modules", "dist", "apps"]
}
